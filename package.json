{
  "name": "nuage-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Automated development pipeline using LLM CLIs and GitHub Issues.",
  "scripts": {
    "dev:runner": "bun run src/runner/index.ts",
    "build": "bun --bun tsc",
    "build:ci": "bun run build && bun run lint && bun run format:check",
    "lint": "bun --bun eslint \"src/**/*.ts\"",
    "lint:fix": "bun --bun eslint \"src/**/*.ts\" --fix",
    "format": "bun --bun prettier --write \"src/**/*.{ts,js,json,md}\" README.md docs/**/*.md repo-map/**/*.yaml",
    "format:check": "bun --bun prettier --check \"src/**/*.{ts,js,json,md}\" README.md docs/**/*.md repo-map/**/*.yaml",
    "test": "bun test",
    "sandbox:setup": "bash scripts/setup-sandbox.sh",
    "sandbox:run": "bun run dev:runner -- --repo-map-dir ./repo-map/sandbox --auto-merge",
    "labels:create": "bun run src/runner/create-labels-cli.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "bun-types": "^1.3.14",
    "eslint": "^10.5.0",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-tsdoc": "^0.5.2",
    "jiti": "^2.7.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "@opentui/core": "^0.4.1"
  }
}